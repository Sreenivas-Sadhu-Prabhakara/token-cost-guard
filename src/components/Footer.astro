---
import { site } from '../site.config.mjs';
---
<footer class="border-t border-[var(--border)] bg-[var(--card)]">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm text-[var(--muted)] sm:flex-row">
    <p>&copy; {new Date().getFullYear()} {site.organization}. All rights reserved.</p>
    <p>{site.name} — {site.tagline}</p>
  </div>
</footer>

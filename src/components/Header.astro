---
import { site } from '../site.config.mjs';
const base = site.base;
---
<header class="sticky top-0 z-40 border-b border-[var(--border)] bg-[var(--bg)]/80 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4" aria-label="Main">
    <a href={base + '/'} class="text-lg font-extrabold tracking-tight">{site.name}</a>
    <div class="flex items-center gap-6 text-sm font-medium">
      <a href="#features" class="text-[var(--muted)] transition hover:text-[var(--fg)]">Features</a>
      <a href="#faq" class="text-[var(--muted)] transition hover:text-[var(--fg)]">FAQ</a>
      <a
        href="#cta"
        class="rounded-lg bg-brand-600 px-4 py-2 font-semibold text-white transition hover:bg-brand-700"
        >Get started</a
      >
    </div>
  </nav>
</header>
